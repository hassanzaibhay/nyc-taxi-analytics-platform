# =============================================================================
# NYC Taxi Analytics Platform — Environment Configuration Template
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================================

# === Data Source ===
TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TLC_START_YEAR=2024
TLC_START_MONTH=1
TLC_END_MONTH=3
TLC_TAXI_TYPE=yellow                    # yellow | green | fhvhv

# === Hadoop ===
HADOOP_NAMENODE_HOST=namenode
HDFS_REPLICATION_FACTOR=1
HADOOP_STREAMING_JAR=/opt/hadoop/share/hadoop/tools/lib/hadoop-streaming-3.4.1.jar

# === Spark ===
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRIPS=nyc-taxi.trips.raw
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_DELAY_MS=10

# === Airflow ===
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=              # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nyc_taxi
POSTGRES_USER=taxi_user
POSTGRES_PASSWORD=                      # SET THIS — never commit passwords

# === MinIO (S3-compatible) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=                    # SET THIS
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=nyc-taxi-raw

# === API Server (FastAPI) ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
CORS_ORIGINS=http://localhost:3000

# === Frontend (React) ===
VITE_API_URL=http://localhost:8000

# === Cloud Deployment ===
AWS_REGION=us-east-1
AWS_PROFILE=default
GCP_PROJECT_ID=
GCP_REGION=us-central1
